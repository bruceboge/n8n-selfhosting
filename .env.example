# ==============================================
# N8N Configuration
# ==============================================
N8N_HOST=yourdomain.com
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=strongpassword
WEBHOOK_URL=https://yourdomain.com/
GENERIC_TIMEZONE=Africa/Nairobi
NODE_ENV=production
DB_TYPE=sqlite
DB_SQLITE_VACUUM_ON_STARTUP=true
N8N_TRUSTED_PROXIES=loopback,linklocal,uniquelocal
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_COMMUNITY_PACKAGES_ALLOW_TOOL_USAGE=true

# ==============================================
# Portainer Configuration
# ==============================================
PORTAINER_HOST=portainer.yourdomain.com
PORTAINER_PORT=9000
PORTAINER_ADMIN_USER=admin
PORTAINER_ADMIN_PASSWORD=strongpassword
PORTAINER_SSL_CERT=/data/ssl/portainer.crt
PORTAINER_SSL_KEY=/data/ssl/portainer.key

# ==============================================
# Caddy Configuration
# ==============================================
CADDY_PORT_HTTP=80
CADDY_PORT_HTTPS=443

# ==============================================
# Watchtower Configuration (Auto-Update)
# ==============================================
# Watchtower runs in docker-compose.yml with these settings:
# - WATCHTOWER_CLEANUP=true (removes old images)
# - WATCHTOWER_POLL_INTERVAL=604800 (checks every 7 days/1 week)
# - WATCHTOWER_LABEL_ENABLE=true (only updates containers with labels)
# 
# Services that AUTO-UPDATE:
# - n8n (has watchtower.enable=true label)
# - Portainer (has watchtower.enable=true label)
#
# Services that DO NOT auto-update:
# - Caddy (no watchtower label)

# ==============================================
# IMPORTANT: Security Notes
# ==============================================
# 1. Replace 'yourdomain.com' with your actual domain
# 2. Change ALL passwords to strong, unique passwords
# 3. Never commit this file to version control
# 4. Use proper secret management in production